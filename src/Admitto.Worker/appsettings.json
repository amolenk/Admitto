{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Azure.Core": "Warning"
    }
  },
  "MessageQueueProcessor": {
    "PollingInterval": "00:00:05",
    "RetryBackoffType": "Exponential", 
    "MaxRetryDelay": "00:00:30",
    "MaxRetryAttempts": 5
  },
  "Registrations": {
    "VerificationToken": {
      "SigningKey": "",
      "TokenTtlMinutes": 15
    },
    "Otp": {
      "ExpiryMinutes": 10,
      "RateLimitWindowMinutes": 10,
      "MaxRequestsPerWindow": 3
    }
  }
}
